modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[[ports]]
localPort = 5000
externalPort = 80

[env]
PORT = "5000"

[deployment]
deploymentTarget = "static"
publicDir = "public"

# Strict anti-cache on HTML so updates show after deploy (browsers + CDNs)
[[deployment.responseHeaders]]
path = "/"
name = "Cache-Control"
value = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
[[deployment.responseHeaders]]
path = "/"
name = "Pragma"
value = "no-cache"
[[deployment.responseHeaders]]
path = "/"
name = "Expires"
value = "0"
[[deployment.responseHeaders]]
path = "/"
name = "Surrogate-Control"
value = "no-store"
[[deployment.responseHeaders]]
path = "/index.html"
name = "Cache-Control"
value = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
[[deployment.responseHeaders]]
path = "/index.html"
name = "Pragma"
value = "no-cache"
[[deployment.responseHeaders]]
path = "/index.html"
name = "Expires"
value = "0"
[[deployment.responseHeaders]]
path = "/index.html"
name = "Surrogate-Control"
value = "no-store"
[[deployment.responseHeaders]]
path = "/index-latest.html"
name = "Cache-Control"
value = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
[[deployment.responseHeaders]]
path = "/index-latest.html"
name = "Pragma"
value = "no-cache"
[[deployment.responseHeaders]]
path = "/index-latest2.html"
name = "Cache-Control"
value = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
[[deployment.responseHeaders]]
path = "/index-latest2.html"
name = "Pragma"
value = "no-cache"
[[deployment.responseHeaders]]
path = "/index-latest3.html"
name = "Cache-Control"
value = "no-store, no-cache, must-revalidate, proxy-revalidate, max-age=0"
[[deployment.responseHeaders]]
path = "/index-latest3.html"
name = "Pragma"
value = "no-cache"
[[deployment.responseHeaders]]
path = "/index-latest3.html"
name = "Expires"
value = "0"
[[deployment.responseHeaders]]
path = "/index-latest3.html"
name = "Surrogate-Control"
value = "no-store"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
